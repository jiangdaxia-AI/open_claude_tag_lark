# Feishu (lark) application credentials — from https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=[REDACTED]

# Feishu bot Open ID — used to filter @bot events in group chats.
# Leave EMPTY to auto-discover at startup via Feishu API (recommended).
# The bot info API will be called with your app_id + app_secret to fetch it.
FEISHU_BOT_OPEN_ID=

# Feishu tenant ID — required. From Feishu open platform "Credentials & Basics" page.
FEISHU_TENANT_ID=xxxxxxxxxxxxxxxx

# ── LLM provider ────────────────────────────────────────────────────────────
# Set LLM_MODEL to any LiteLLM model string and provide the matching API key.
#
# Option A: OpenAI-compatible self-hosted gateway (e.g. gray-ai-gateway)
#   LLM_MODEL must be prefixed with "openai/" so LiteLLM routes via the
#   custom_llm_provider path. LLM_API_BASE is the gateway's /v1 endpoint.
# LLM_MODEL=openai/qwen3.5-flash
# LLM_API_BASE=https://gray-ai-gateway.example.com/coding/qwen/v1
# LLM_API_KEY=[REDACTED]
#
# Option B: native Anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=[REDACTED]
# OpenAI
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=[REDACTED]
# DeepSeek
# LLM_MODEL=deepseek/deepseek-chat
# DEEPSEEK_API_KEY=[REDACTED]
# Local Ollama
# LLM_MODEL=ollama/llama3

# Storage
DATA_DIR=./data

# ── Vision model ───────────────────────────────────────────────────────────
# VISION_MODEL=Qwen2.5-VL-72B
# VISION_API_BASE=http://localhost:8000/v1
# VISION_API_KEY=[REDACTED]

# ── Heartbeat model ─────────────────────────────────────────────────────────
# HEARTBEAT_MODEL=qwen3.5-instruct
# HEARTBEAT_API_BASE=http://localhost:8000/v1
# HEARTBEAT_API_KEY=[REDACTED]

# ── Memory compaction ───────────────────────────────────────────────────────
# MEMORY_MAX_TOKENS=2000
# MEMORY_COMPACT_THRESHOLD=0.8
# MEMORY_EXPIRY_DAYS_P1=365
# MEMORY_EXPIRY_DAYS_P2=60
# MEMORY_EXPIRY_DAYS_P3=14

# ── Curation model ──────────────────────────────────────────────────────────
# CURATION_MODEL=
# CURATION_API_BASE=
# CURATION_API_KEY=

# ── Mem0 semantic recall ────────────────────────────────────────────────────
# MEM0_ENABLED=false
# MEM0_LLM_MODEL=
# MEM0_LLM_API_BASE=
# MEM0_LLM_API_KEY=
# MEM0_EMBEDDER_MODEL=BAAI/bge-small-zh-v1.5
# MEM0_EMBEDDER_API_BASE=
# MEM0_EMBEDDER_API_KEY=
# MEM0_VECTOR_STORE_PATH=
# MEM0_SEARCH_TOP_K=5

# ── Agent lifecycle ─────────────────────────────────────────────────────────
# How long (seconds) before an idle agent goes to sleep to save tokens.
AGENT_IDLE_TIMEOUT_SECONDS=600

# ── Web admin server ────────────────────────────────────────────────────────
# Enable the built-in web dashboard for task boards and agent management.
# Requires: pip install fastapi uvicorn
# WEB_ADMIN_ENABLED=false
# WEB_ADMIN_HOST=0.0.0.0
# WEB_ADMIN_PORT=8765

# ── Multi-agent config ──────────────────────────────────────────────────────
# Per-channel agents are configured in data/channels/<channel_id>/agents.toml
# Each agent can have its own Feishu bot (Q1:B multi-bot mode).
# See channels/example/agents.toml for an example.
